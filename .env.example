# ============================================================
# 세컨드브레인 환경 변수 예시
# 이 파일을 .env로 복사하고 실제 값을 채워넣으세요
# .env는 절대 Git에 커밋하지 마세요!
# ============================================================

# ── Claude API ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── OpenAI API (LightRAG 임베딩용) ──────────────────────────
OPENAI_API_KEY=sk-...

# ── n8n ─────────────────────────────────────────────────────
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=your-password-here
N8N_HOST=localhost
N8N_PORT=5678

# ── MiniFlux (RSS 리더) ─────────────────────────────────────
MINIFLUX_DATABASE_URL=postgres://miniflux:miniflux@db/miniflux?sslmode=disable
MINIFLUX_ADMIN_USERNAME=admin
MINIFLUX_ADMIN_PASSWORD=your-password-here

# ── LightRAG ────────────────────────────────────────────────
LIGHTRAG_HOST=localhost
LIGHTRAG_PORT=7860

# ── Obsidian Vault 경로 ─────────────────────────────────────
OBSIDIAN_VAULT_PATH=C:/KJS/AVARTA/secondBrain/vault

# ── Slack 알림 (선택) ────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ── Notion API (Phase E, 선택) ──────────────────────────────
NOTION_API_KEY=secret_...
NOTION_DATABASE_ID=...

# ── GitHub (Phase F, 선택) ──────────────────────────────────
GITHUB_TOKEN=ghp_...
GITHUB_REPO=your-username/secondbrain
